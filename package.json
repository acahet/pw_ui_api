{
	"name": "playwright-template",
	"version": "1.0.0",
	"main": "index.js",
	"repository": "https://github.com/acahet/playwright-template.git",
	"author": "Anderson Cahet",
	"license": "MIT",
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "^2.4.0",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.3.0",
		"@playwright/test": "^1.58.2",
		"@types/node": "^25.5.0",
		"ajv": "^8.18.0",
		"dotenv": "^17.3.1",
		"eslint": "^10.0.3",
		"eslint-plugin-playwright": "^2.9.0",
		"genson-js": "^0.0.8",
		"http-server": "^14.1.1",
		"husky": "^9.1.7",
		"playwright-smart-reporter": "^1.6.5",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0"
	},
	"scripts": {
		"code:format": "biome format --write .",
		"code:check": "biome check --write .",
		"code:lint": "biome lint --write .",
		"code:lint:playwright": "eslint --fix tests/**/*.ts",
		"code:all": "yarn code:check && yarn code:lint:playwright",
		"code:ci": "biome ci . && eslint --cache tests/**/*.ts",
		"test:all": "npx playwright test --workers=1",
		"test:ci": "npx playwright test",
		"test:ui": "npx playwright test --project ui-tests",
		"test:api": "npx playwright test --project api-tests",
		"test:ui-mode": "npx playwright test --ui",
		"report": "yarn playwright show-report tests/report/playwright-report",
		"report:history": "node scripts/start-history-server.js",
		"prepare": "husky"
	}
}
